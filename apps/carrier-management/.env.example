# Carrier Management — Environment Variables
#
# This app works with ZERO configuration out of the box.
# All variables below are optional and show defaults.
#
# Copy this file to .env.local to override any values:
#   cp .env.example .env.local

# ─── Database ────────────────────────────────────────────────
# Default: local SQLite file in project root (zero setup)
# For production, you can point to a libSQL/Turso instance
# DATABASE_URL=file:./carrier-management.db

# ─── Server ──────────────────────────────────────────────────
# PORT=3001
